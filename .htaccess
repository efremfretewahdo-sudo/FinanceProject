<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS (active in production; comment out for localhost)
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Block direct access to sensitive root files
    RewriteRule ^(\.env|\.env\..+|composer\.(json|lock)|package(-lock)?\.json|artisan|phpunit\.xml|vite\.config\.js)$ - [F,L]

    # Block direct access to Laravel internals
    RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|tests|vendor)(/|$) - [F,L]

    # Route all other requests to public/
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L,QSA]
</IfModule>

# Disable directory listing
Options -Indexes

# FilesMatch fallback for servers where mod_rewrite is limited
<FilesMatch "^(\.env|\.env\..+|composer\.(json|lock)|package(-lock)?\.json|artisan|phpunit\.xml)$">
    Order allow,deny
    Deny from all
</FilesMatch>
